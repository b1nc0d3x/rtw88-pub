From: Kyle Crenshaw <b1nc0d3x@gmail.com>
Date: 2026-06-28
Subject: [PATCH] linuxkpi: usb endpoint-descriptor helpers + speed enum

Adds the missing pieces in linux/usb.h that LinuxKPI-wrapped Linux
USB drivers (rtw88, rtw89, mt76x{0,2}u, ath10k_usb) need to walk
descriptors and probe endpoints.  The structs themselves
(`struct usb_host_interface`, `struct usb_host_endpoint`) already
exist in dev/usb/usb_device.h with the right `.desc` member — they
just weren't exposed to LinuxKPI consumers.

Adds:
 - `enum usb_device_speed` typedef to FreeBSD's `enum usb_dev_speed`
 - `usb_endpoint_num` / `usb_endpoint_dir_in` / `usb_endpoint_dir_out` /
   `usb_endpoint_xfer_bulk` / `usb_endpoint_xfer_int` inline helpers
   (pure bit extraction over the USB-standard endpoint descriptor;
   same on both OSes)
 - `usb_get_dev` / `usb_put_dev` as inline stubs (LinuxKPI's
   usb_device has no separate refcount; reuses the usb_interface
   binding lifetime)

Doesn't touch behaviour for any existing LinuxKPI USB driver.

Unblocks rtw88, rtw89, mt76 (mt7615u/mt7921u/mt7925u/mt76x2u) USB
builds.  Tested by walking through compile of sys/modules/rtw88 with
USB SRCS enabled — the build error count drops from "fatal: too many
errors emitted" to the next layer (struct usb_device field access),
which is a separate companion patch.

---
 sys/compat/linuxkpi/common/include/linux/usb.h | 47 +++++++++++++++++++
 1 file changed, 47 insertions(+)

diff --git a/sys/compat/linuxkpi/common/include/linux/usb.h b/sys/compat/linuxkpi/common/include/linux/usb.h
--- a/sys/compat/linuxkpi/common/include/linux/usb.h
+++ b/sys/compat/linuxkpi/common/include/linux/usb.h
@@ -33,6 +33,8 @@
 #ifndef _LINUXKPI_LINUX_USB_H
 #define	_LINUXKPI_LINUX_USB_H

+#include <dev/usb/usb_device.h>	/* struct usb_host_interface, usb_host_endpoint */
+
 #include <linux/list.h>
 #include <linux/kernel.h>
 #include <linux/types.h>
@@ -50,6 +52,15 @@ struct usb_interface;
 struct usb_driver;

 #define	BCD_USB_2_0	0x0200
+
+/* Linux's `enum usb_device_speed` maps to FreeBSD's `enum usb_dev_speed`.
+ * Values USB_SPEED_LOW / FULL / HIGH / SUPER are common to both. */
+#define	usb_device_speed	usb_dev_speed
+
+/* Inline refcount stubs.  LinuxKPI binds a usb_device to its parent
+ * usb_interface for the device lifetime; no separate refcount path. */
+static inline struct usb_device *usb_get_dev(struct usb_device *udev) { return udev; }
+static inline void usb_put_dev(struct usb_device *udev) { (void)udev; }

 #define	USB_DEVICE_ID_MATCH_VENDOR	0x0001
 #define	USB_DEVICE_ID_MATCH_PRODUCT	0x0002
@@ -313,4 +324,40 @@ int	usb_bulk_msg(struct usb_device *, struct usb_host_endpoint *,
 #define	USB_DEVICE_ID_MATCH_INT_PROTOCOL	0x0400
 #define	USB_DEVICE_ID_MATCH_INT_NUMBER	0x0800

+/*
+ * Endpoint descriptor helpers.  Pure bit extraction over the USB-standard
+ * descriptor; FreeBSD's UE_* and Linux's USB_ENDPOINT_* bit positions are
+ * identical so the same operations work on both.
+ */
+static inline int
+usb_endpoint_num(const struct usb_endpoint_descriptor *epd)
+{
+	return (epd->bEndpointAddress & UE_ADDR);
+}
+
+static inline int
+usb_endpoint_dir_in(const struct usb_endpoint_descriptor *epd)
+{
+	return ((epd->bEndpointAddress & UE_DIR_IN) == UE_DIR_IN);
+}
+
+static inline int
+usb_endpoint_dir_out(const struct usb_endpoint_descriptor *epd)
+{
+	return ((epd->bEndpointAddress & UE_DIR_IN) == 0);
+}
+
+static inline int
+usb_endpoint_xfer_bulk(const struct usb_endpoint_descriptor *epd)
+{
+	return ((epd->bmAttributes & UE_XFERTYPE) == UE_BULK);
+}
+
+static inline int
+usb_endpoint_xfer_int(const struct usb_endpoint_descriptor *epd)
+{
+	return ((epd->bmAttributes & UE_XFERTYPE) == UE_INTERRUPT);
+}
+
 #endif					/* _LINUXKPI_LINUX_USB_H */
